# Environment variables for the competitive-intel-agents runtime.
# Copy this file to .env (which is git-ignored) and fill in your keys,
# OR export the values directly in your shell.

# ── Model provider ─────────────────────────────────────────────
# Either provider+endpoint+key+model below, or copy config/model.example.json
# to config/model.json and edit. Env vars take precedence over the JSON file.
# CIA_MODEL_PROVIDER=anthropic-compatible
# CIA_MODEL_ENDPOINT=https://api.anthropic.com
# CIA_MODEL_API_KEY=sk-ant-...
# CIA_MODEL_NAME=claude-opus-4-5

# ── Search provider (Module 34) ─────────────────────────────────
# Default chain when no API key is set: DuckDuckGo HTML → Bing HTML.
# Setting CIA_SERPER_API_KEY automatically promotes Serper to the
# front of the FallbackSearch chain (HTML adapters remain as
# fallbacks). Get a free key at https://serper.dev (2500 free queries
# per month at the time of writing).
# CIA_SERPER_API_KEY=
#
# CIA_SEARCH_PROVIDER=auto    # default; serper-led when key is set
# CIA_SEARCH_PROVIDER=html    # force HTML-only (skip Serper even if keyed)
# CIA_SEARCH_PROVIDER=serper  # Serper-only (no HTML fallback)

# ── Wall-clock timeout (Module 33) ──────────────────────────────
# Maximum seconds a single run is allowed to take. The Orchestrator
# checks the deadline at every agent boundary and at the top of each
# rework iteration. When the deadline trips and a report has already
# been written, the run ships as approved_with_caveats with a
# synthetic timeout caveat; otherwise it aborts.
#
# CIA_MAX_RUN_SECONDS=600   # default
# CIA_MAX_RUN_SECONDS=300   # tighter SLA
# CIA_MAX_RUN_SECONDS=0     # disable the deadline (debug mode)
